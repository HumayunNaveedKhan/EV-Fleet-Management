static void logSheet(){
#if GS_ENABLE
  if(WiFi.status()!=WL_CONNECTED||!b.valid)return;
  static uint32_t last=0;if(millis()-last<GS_MIN_MS)return;last=millis();
  String q="?id="+String(g_selMac)+"&v="+String(b.v,1)+"&i="+String(b.i,1)+"&soc="+String(b.soc,1)
    +"&ah="+String(b.ah,1)+"&kw="+String(b.kw,3)+"&eo="+String((float)b.kwhOut,3)+"&cyc="+String(b.cyc)
    +"&dmv="+String(b.dmv)+"&t="+String(b.temp)+"&hv="+verdict()
    +"&lat="+String(g.lat,6)+"&lon="+String(g.lon,6)+"&spd="+String(g.spd,1)+"&sat="+String(g.sats)+"&fix="+String(g.fix?1:0);
  WiFiClientSecure cli;cli.setInsecure();
  if(!cli.connect(GS_HOST,443)){Serial.println("[GS] connect fail");return;}
  cli.print(String("GET ")+GS_PATH+q+" HTTP/1.1\r\nHost: "+GS_HOST+"\r\nConnection: close\r\n\r\n");
  uint32_t t=millis();while(cli.connected()&&millis()-t<4000){if(cli.available())cli.read();}cli.stop();
  Serial.println("[GS] row sent");
#endif
}

