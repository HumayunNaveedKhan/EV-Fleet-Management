static uint16_t be16(const uint8_t*p){return (uint16_t)p[0]<<8|p[1];}
static uint32_t be32(const uint8_t*p){return (uint32_t)p[0]<<24|(uint32_t)p[1]<<16|(uint32_t)p[2]<<8|p[3];}
static const char* verdict(){if(fabsf(b.i)>REST_A)return "LOAD";if(b.dmv<DELTA_WATCH)return "OK";if(b.dmv<DELTA_ALARM)return "WATCH";return "ALARM";}

// ---- GNSS ------------------------------------------------------------------
static double nmeaDeg(const char*f,char q){double raw=atof(f);int d=(int)(raw/100);double dec=d+(raw-d*100)/60.0;return (q=='S'||q=='W')?-dec:dec;}
static void gnssLine(char*s){
  if(!strstr(s,"RMC")&&!strstr(s,"GGA"))return;
  char*t[16];int n=0; for(char*p=strtok(s,",");p&&n<16;p=strtok(NULL,","))t[n++]=p;
  if(n<7)return;
  if(strstr(t[0],"RMC")){ if(t[2][0]=='A'){g.lat=nmeaDeg(t[3],t[4][0]);g.lon=nmeaDeg(t[5],t[6][0]);g.spd=atof(t[7])*1.852f;g.fix=true;g.lastMs=millis();} else g.fix=false; }
  else if(strstr(t[0],"GGA")&&n>7){g.sats=atoi(t[7]);}
}
static void gnssPoll(){static char L[100];static uint8_t li=0;
  while(GNSS.available()){char c=GNSS.read();
    if(c=='\n'){L[li]=0;if(li>6)gnssLine(L);li=0;} else if(c!='\r'&&li<99)L[li++]=c;}}

// ---- 0xA5 BMS --------------------------------------------------------------
enum:uint8_t{A5_SOC=0x90,A5_MOS=0x93,A5_STAT=0x94,A5_CV=0x95,A5_CT=0x96,A5_BAL=0x97,A5_FLT=0x98};
static void a5(uint8_t cmd){uint8_t f[13]={0};f[0]=0xA5;f[1]=0x80;f[2]=cmd;f[3]=8;uint8_t cs=0;for(int i=0;i<12;i++)cs+=f[i];f[12]=cs;if(g_wr)g_wr->writeValue(f,13,false);}
static void cellStats(){if(!b.ns)return;uint32_t sum=0;uint16_t mn=0xFFFF,mx=0;uint8_t mni=0,mxi=0,c=0;
  for(uint8_t i=0;i<b.ns;i++){uint16_t v=b.cellmV[i];if(!v)continue;sum+=v;c++;if(v<mn){mn=v;mni=i+1;}if(v>mx){mx=v;mxi=i+1;}}
  if(c!=b.ns)return;b.avg=sum/c;b.mn=mn;b.mni=mni;b.mx=mx;b.mxi=mxi;b.dmv=mx-mn;}
static void energy(){static uint32_t last=0;uint32_t now=millis();if(!last){last=now;return;}uint32_t dt=now-last;last=now;if(dt>30000)return;double k=(b.v*b.i/1000.0)*(dt/3600000.0);if(b.i>0.1)b.kwhIn+=k;else if(b.i<-0.1)b.kwhOut+=-k;}
static void a5Parse(const uint8_t*f){const uint8_t*d=&f[4];switch(f[2]){
  case A5_SOC:b.v=be16(d)*0.1f;b.i=((int32_t)be16(d+4)-30000)*0.1f;b.soc=be16(d+6)*0.1f;b.kw=b.v*b.i/1000.0f;energy();b.valid=true;b.lastMs=millis();break;
  case A5_MOS:b.st=d[0];b.chg=d[1];b.dsg=d[2];b.life=d[3];b.ah=be32(d+4)/1000.0f;break;
  case A5_STAT:if(d[0]&&d[0]<=MAX_CELLS)b.ns=d[0];b.cyc=be16(d+5);break;
  case A5_CV:{uint8_t fr=d[0];if(!fr||fr>6)break;for(uint8_t i=0;i<3;i++){uint8_t x=(fr-1)*3+i;if(x>=MAX_CELLS)break;uint16_t mv=be16(d+1+i*2);if(mv&&mv<5000)b.cellmV[x]=mv;}if(b.ns&&fr>=(b.ns+2)/3)cellStats();break;}
  case A5_CT:b.temp=(int16_t)d[1]-40;break;
  case A5_BAL:{bool a=false;for(uint8_t i=0;i<6;i++)if(d[i])a=true;b.bal=a;break;}
  case A5_FLT:{bool a=false;for(uint8_t i=0;i<7;i++)if(d[i])a=true;b.fault=a;break;}}}
static void a5Consume(){size_t i=0;while(g_rxN-i>=13){if(g_rx[i]!=0xA5){i++;continue;}uint8_t cs=0;for(int k=0;k<12;k++)cs+=g_rx[i+k];if(cs!=g_rx[i+12]){i++;continue;}a5Parse(&g_rx[i]);i+=13;}if(i){memmove(g_rx,g_rx+i,g_rxN-i);g_rxN-=i;}}

// ---- BLE -------------------------------------------------------------------
static void onNotify(NimBLERemoteCharacteristic*c,uint8_t*data,size_t len,bool n){if(g_rxN+len>sizeof(g_rx))g_rxN=0;memcpy(g_rx+g_rxN,data,len);g_rxN+=len;if(g_proto==P_NONE)for(size_t i=0;i<g_rxN;i++)if(g_rx[i]==0xA5){g_proto=P_A5;break;}if(g_proto==P_A5)a5Consume();}
class CliCB:public NimBLEClientCallbacks{void onConnect(NimBLEClient*c)override{c->updateConnParams(24,48,0,400);g_online=true;}void onDisconnect(NimBLEClient*c,int r)override{g_online=false;b.valid=false;g_proto=P_NONE;g_rxN=0;}};
static CliCB g_cliCB;
class ScanCB:public NimBLEScanCallbacks{void onResult(const NimBLEAdvertisedDevice*d)override{
  if(!d->haveName())return;std::string nm=d->getName();if(nm.rfind("DL-",0)!=0)return;std::string mac=d->getAddress().toString();
  bool known=false;for(uint8_t i=0;i<g_nFound;i++)if(!strcmp(g_found[i].mac,mac.c_str())){g_found[i].rssi=d->getRSSI();known=true;break;}
  if(!known&&g_nFound<MAX_FOUND){strncpy(g_found[g_nFound].name,nm.c_str(),19);strncpy(g_found[g_nFound].mac,mac.c_str(),17);g_found[g_nFound].rssi=d->getRSSI();g_nFound++;}
  if(g_haveSel&&!g_online&&!strcmp(mac.c_str(),g_selMac)){NimBLEDevice::getScan()->stop();g_target=const_cast<NimBLEAdvertisedDevice*>(d);g_connect=true;}}};
static ScanCB g_scanCB;
static bool connectSel(){if(!g_cli){g_cli=NimBLEDevice::createClient();g_cli->setClientCallbacks(&g_cliCB,false);g_cli->setConnectTimeout(10000);}
  if(!g_cli->connect(g_target))return false;NimBLERemoteService*s=g_cli->getService(SVC);if(!s){g_cli->disconnect();return false;}
  NimBLERemoteCharacteristic*nf=s->getCharacteristic(C_NOTIFY);g_wr=s->getCharacteristic(C_WRITE);if(!nf||!g_wr){g_cli->disconnect();return false;}
  if(!nf->subscribe(true,onNotify)){g_cli->disconnect();return false;}a5(A5_SOC);delay(300);return true;}
static void pollBms(){static const uint8_t cs[]={A5_SOC,A5_MOS,A5_STAT,A5_CV,A5_CT,A5_BAL,A5_FLT};for(uint8_t c:cs){a5(c);delay(45);web.handleClient();gnssPoll();}}

