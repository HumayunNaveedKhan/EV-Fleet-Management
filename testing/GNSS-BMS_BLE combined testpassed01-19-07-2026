</div>

<script>
const $=i=>document.getElementById(i);
const C=540.4; let miss=0;

function paint(d){
 $('bid').textContent=d.id;
 $('sub').textContent=d.ns+'S LiFePO4 · '+d.ahn+' Ah · '+d.rssi+' dBm';
 const on=d.ok==1;
 $('dot').className='dot'+(on?' on':'');
 $('lnk').textContent=on?'LIVE':'NO DATA';
 $('wrap').className=on?'':'off';

 const soc=d.soc;
 $('soc').textContent=soc.toFixed(1);
 $('arc').style.strokeDashoffset=C-(C*Math.min(soc,100)/100);
 $('arc').style.stroke=soc>50?'var(--ok)':soc>20?'var(--warn)':'var(--bad)';

 const S=['IDLE','CHARGING','DISCHARGING'][d.st]||'IDLE';
 $('st').textContent=S;
 $('st').style.color=d.st==1?'var(--ok)':d.st==2?'var(--acc)':'var(--dim)';

 $('v').textContent=d.v.toFixed(1);
 $('i').textContent=d.i.toFixed(1);
 $('i').style.color=d.i<-.1?'var(--acc)':d.i>.1?'var(--ok)':'var(--tx)';
 $('kw').textContent=Math.abs(d.kw).toFixed(2);
 $('ah').textContent=d.ah.toFixed(1);
 $('tp').textContent=d.t.length?d.t[0]:'--';
 $('cyc').textContent=d.cyc;
 $('eo').textContent=d.eout.toFixed(3);
 $('ei').textContent=d.ein.toFixed(3);

 // GPS Injection
 $('spd').textContent=d.spd.toFixed(1);
 $('sats').textContent=d.sats;
 $('hdop').textContent=d.hdop<99?' (HDOP: '+d.hdop+')':'';
 if(d.lat!==0 || d.lng!==0){
   $('loc').innerHTML='<a href="https://maps.google.com/?q='+d.lat+','+d.lng+'" target="_blank" class="map-link">'+d.lat.toFixed(6)+', '+d.lng.toFixed(6)+' ↗</a>';
 }else{
   $('loc').textContent='Acquiring satellites...';
 }

 $('mn').textContent=d.mn; $('mni').textContent='#'+d.mni;
 $('mx').textContent=d.mx; $('mxi').textContent='#'+d.mxi;
 $('dmv').textContent=d.dmv;

 const hb=$('hb'); hb.textContent=d.hv;
 const col={'HEALTHY':'--ok','WATCH':'--warn','INVESTIGATE':'--warn','ALARM':'--bad','UNDER LOAD':'--vio'}[d.hv]||'--dim';
 hb.style.background='color-mix(in srgb,var('+col+') 16%,transparent)';
 hb.style.color='var('+col+')';

 const lo=d.mn-3, hi=d.mx+3, sp=Math.max(hi-lo,1);
 let h='';
 d.c.forEach((mv,k)=>{
   const w=Math.max(3,Math.min(100,(mv-lo)/sp*100));
   const cls=(k+1)==d.mxi?'fill hi':(k+1)==d.mni?'fill lo':'fill';
   h+='<div class="cell"><span class="n">'+(k+1)+'</span><div class="bar">'+
      '<div class="'+cls+'" style="width:'+w+'%"></div></div>'+
      '<span class="mv">'+mv+'</span></div>';
 });
 $('cl').innerHTML=h;

 const set=(id,on)=>{const e=$(id);e.textContent=on?'ON':'OFF';
   e.style.color=on?'var(--ok)':'var(--dim)';};
 set('cm',d.chg); set('dm',d.dsg);
 $('bl').textContent=d.bal?'ON':'OFF';
 $('bl').style.color=d.bal?'var(--warn)':'var(--dim)';
 $('lf').textContent=d.life;
 $('lf').style.color='var(--tx)';

 if(d.f.length){$('fc').style.display='block';
   $('fl').innerHTML=d.f.map(x=>'<div>▲ '+x+'</div>').join('');}
 else $('fc').style.display='none';

 const u=d.up,hh=(u/3600|0),mm=(u%3600/60|0);
 $('ft').textContent='avg cell '+d.avg+' mV · uptime '+hh+'h '+mm+'m';
}

async function tick(){
 try{
  const r=await fetch('/api/data',{cache:'no-store'});
  paint(await r.json()); miss=0;
 }catch(e){
  if(++miss>3){$('dot').className='dot';$('lnk').textContent='NO LINK';
   $('wrap').className='off';}
 }
}
tick(); setInterval(tick,1000);
</script></body></html>)HTML";

static void handleRoot() { server.send_P(200, "text/html", PAGE); }

// ---------------------------------------------------------------------------
// SETUP / LOOP
// ---------------------------------------------------------------------------
void setup() {
  Serial.begin(115200);
  
  // Prevent buffer overflow when BLE delays block the main loop
  GPS.setRxBufferSize(1024);
  GPS.begin(GNSS_BAUD, SERIAL_8N1, GNSS_RX, GNSS_TX);

  const uint32_t t0 = millis();
  while (!Serial && millis() - t0 < 3000) delay(10);
  delay(300);

  Serial.println(F("\n\n=== DALY BMS + GNSS dashboard (ESP32-C3) ==="));

  WiFi.mode(WIFI_AP);
  WiFi.softAP(AP_SSID, AP_PASS);
  Serial.printf("WiFi AP  : %s / %s\n", AP_SSID, AP_PASS);
  Serial.printf("Dashboard: http://%s\n", WiFi.softAPIP().toString().c_str());
  if (MDNS.begin(MDNS_NAME)) Serial.printf("      or : http://%s.local\n", MDNS_NAME);

  server.on("/", handleRoot);
  server.on("/api/data", handleData);
  server.begin();

  NimBLEDevice::init("");
  NimBLEDevice::setPower(ESP_PWR_LVL_P9);
  NimBLEScan *s = NimBLEDevice::getScan();
  s->setScanCallbacks(&g_scanCB, false);
  s->setActiveScan(true);
  s->setInterval(100);
  s->setWindow(80);
  s->start(SCAN_TIME_S, false);
  Serial.println("Scanning for BMS...\n");
}

void loop() {
  feedGPS();               // Read GNSS characters continuously
  server.handleClient();   // Keep the UI responsive

  static uint32_t lastPoll = 0;
  
  if (g_doConnect) {
    g_doConnect = false;
    if (!connectToBms()) { 
      uint32_t t = millis();
      // Wait before retry, but keep feeding GPS buffer
      while(millis() - t < 1500) { feedGPS(); delay(10); } 
      NimBLEDevice::getScan()->start(SCAN_TIME_S, false); 
    }
  }
  
  if (g_connected && millis() - lastPoll >= POLL_INTERVAL_MS) {
    lastPoll = millis();
    pollBms();
  }
  
  if (!g_connected && !g_doConnect && !NimBLEDevice::getScan()->isScanning())
    NimBLEDevice::getScan()->start(SCAN_TIME_S, false);
}
