static const char *deltaVerdict() {
  if (fabsf(g_bms.current) > REST_CURRENT_A) return "UNDER LOAD";
  const uint16_t d = g_bms.cellDeltamV;
  if (d < DELTA_WATCH_MV)    return "HEALTHY";
  if (d < DELTA_INVESTIGATE) return "WATCH";
  if (d < DELTA_ALARM_MV)    return "INVESTIGATE";
  return "ALARM";
}

// ---------------------------------------------------------------------------
// 0xA5 BMS PROTOCOL
// ---------------------------------------------------------------------------
enum : uint8_t {
  A5_SOC = 0x90, A5_MINMAX_V = 0x91, A5_MINMAX_T = 0x92, A5_MOS = 0x93,
  A5_STATUS = 0x94, A5_CELL_V = 0x95, A5_CELL_T = 0x96,
  A5_BALANCE = 0x97, A5_FAULTS = 0x98
};

static void a5Send(uint8_t cmd) {
  uint8_t f[13] = {0};
  f[0] = 0xA5; f[1] = 0x80; f[2] = cmd; f[3] = 0x08;
  uint8_t cs = 0;
  for (int i = 0; i < 12; i++) cs += f[i];
  f[12] = cs;
  if (g_chrWrite) g_chrWrite->writeValue(f, 13, false);
}

static void recomputeCellStats() {
  if (!g_bms.cellCount) return;
  uint32_t sum = 0;
  uint16_t mn = 0xFFFF, mx = 0;
  uint8_t mni = 0, mxi = 0, n = 0;
  for (uint8_t i = 0; i < g_bms.cellCount; i++) {
    const uint16_t v = g_bms.cellmV[i];
    if (!v) continue;
    sum += v; n++;
    if (v < mn) { mn = v; mni = i + 1; }
    if (v > mx) { mx = v; mxi = i + 1; }
  }
  if (n != g_bms.cellCount) return;      
  g_bms.avgCellmV   = sum / n;
  g_bms.minCellmV   = mn; g_bms.minCellNum = mni;
  g_bms.maxCellmV   = mx; g_bms.maxCellNum = mxi;
  g_bms.cellDeltamV = mx - mn;
}

static void integrateEnergy() {
  static uint32_t lastMs = 0;
  const uint32_t now = millis();
  if (!lastMs) { lastMs = now; return; }
  const uint32_t dt = now - lastMs;
  lastMs = now;
  if (dt > 30000) return;                
  const double kwh = (g_bms.powerW / 1000.0) * (dt / 3600000.0);
  if (g_bms.current > 0.1f)       g_bms.kWhIn  += kwh;
  else if (g_bms.current < -0.1f) g_bms.kWhOut += -kwh;
}

static void a5Parse(const uint8_t *f) {
  const uint8_t cmd = f[2];
  const uint8_t *d = &f[4];
  switch (cmd) {
    case A5_SOC:
      g_bms.packVoltage = be16(d) * 0.1f;
      g_bms.current = ((int32_t)be16(d + 4) - 30000) * 0.1f; 
      g_bms.soc     = be16(d + 6) * 0.1f;
      g_bms.powerW  = g_bms.packVoltage * g_bms.current;
      g_bms.powerKW = g_bms.powerW / 1000.0f;
      integrateEnergy();
      g_bms.valid = true;
      g_bms.lastUpdateMs = millis();
      break;
    case A5_MINMAX_T: break;
    case A5_MOS:
      g_bms.chargeState = d[0];
      g_bms.chgMos = d[1];
      g_bms.dsgMos = d[2];
      g_bms.bmsLife = d[3];
      g_bms.remainingAh = be32(d + 4) / 1000.0f;
      break;
    case A5_STATUS:
      if (d[0] > 0 && d[0] <= MAX_CELLS) g_bms.cellCount = d[0];
      if (d[1] > 0 && d[1] <= MAX_TEMPS) g_bms.tempCount = d[1];
      g_bms.cycles = be16(d + 5);
      break;
    case A5_CELL_V: {
      const uint8_t fr = d[0];
      if (!fr || fr > 11) break;
      for (uint8_t i = 0; i < 3; i++) {
        const uint8_t idx = (fr - 1) * 3 + i;
        if (idx >= MAX_CELLS) break;
        const uint16_t mv = be16(d + 1 + i * 2);
        if (mv > 0 && mv < 5000) g_bms.cellmV[idx] = mv;
      }
      if (g_bms.cellCount && fr >= (g_bms.cellCount + 2) / 3) recomputeCellStats();
      break;
    }
    case A5_CELL_T: {
      const uint8_t fr = d[0];
      if (!fr) break;
      for (uint8_t i = 0; i < 7; i++) {
        const uint8_t idx = (fr - 1) * 7 + i;
        if (idx >= MAX_TEMPS) break;
        g_bms.tempC[idx] = (int16_t)d[1 + i] - 40;
      }
      break;
    }
    case A5_BALANCE: {
      bool any = false;
      for (uint8_t i = 0; i < 6 && !any; i++) if (d[i]) any = true;
      g_bms.balancing = any;
      break;
    }
    case A5_FAULTS: {
      bool any = false;
      for (uint8_t i = 0; i < 7; i++) { g_bms.faultBytes[i] = d[i]; if (d[i]) any = true; }
      g_bms.anyFault = any;
      break;
    }
    default: break;
  }
}

static void a5Consume() {
  size_t i = 0;
  while (g_rxLen - i >= 13) {
    if (g_rx[i] != 0xA5) { i++; continue; }
    uint8_t cs = 0;
    for (int k = 0; k < 12; k++) cs += g_rx[i + k];
    if (cs != g_rx[i + 12]) { i++; continue; }
    a5Parse(&g_rx[i]);
    i += 13;
  }
  if (i) { memmove(g_rx, g_rx + i, g_rxLen - i); g_rxLen -= i; }
}

// ---------------------------------------------------------------------------
// 0xD2 BMS PROTOCOL (Fallback)
// ---------------------------------------------------------------------------
static void d2SendReadAll() {
  uint8_t f[8] = {0xD2, 0x03, 0x00, 0x00, 0x00, 0x3E, 0, 0};
  const uint16_t c = crc16(f, 6);
  f[6] = c & 0xFF; f[7] = c >> 8;
  if (g_chrWrite) g_chrWrite->writeValue(f, 8, false);
}
static void d2Parse(const uint8_t *p, size_t n) {
  const uint8_t bc = p[2];
  if (n < (size_t)(3 + bc + 2)) return;
  const uint8_t *d = p + 3;
  auto reg = [&](uint8_t r) { return be16(d + r * 2); };
  uint8_t cells = 0;
  for (uint8_t i = 0; i < 32; i++) {
    const uint16_t mv = reg(i);
    if (mv > 500 && mv < 5000) { g_bms.cellmV[i] = mv; cells = i + 1; }
  }
  if (cells) g_bms.cellCount = cells;
  uint8_t temps = 0;
  for (uint8_t i = 0; i < 8; i++) {
    const int16_t t = (int16_t)reg(32 + i) - 40;
    if (t > -40 && t < 125) { g_bms.tempC[i] = t; temps = i + 1; }
  }
  if (temps) g_bms.tempCount = temps;
  g_bms.packVoltage = reg(40) * 0.1f;
  g_bms.current = ((int32_t)reg(42) - 30000) * 0.1f;
  g_bms.soc = reg(43) * 0.1f;
  g_bms.powerW = g_bms.packVoltage * g_bms.current;
  g_bms.powerKW = g_bms.powerW / 1000.0f;
  recomputeCellStats();
  integrateEnergy();
  g_bms.valid = true;
  g_bms.lastUpdateMs = millis();
}
static void d2Consume() {
  size_t i = 0;
  while (g_rxLen - i >= 5) {
    if (g_rx[i] != 0xD2 || g_rx[i + 1] != 0x03) { i++; continue; }
    const size_t total = 3 + g_rx[i + 2] + 2;
    if (g_rxLen - i < total) break;
    const uint16_t got = g_rx[i + total - 2] | (g_rx[i + total - 1] << 8);
    if (got != crc16(&g_rx[i], total - 2)) { i++; continue; }
    d2Parse(&g_rx[i], total);
    i += total;
  }
  if (i) { memmove(g_rx, g_rx + i, g_rxLen - i); g_rxLen -= i; }
}

// ---------------------------------------------------------------------------
// BLE PLUMBING
// ---------------------------------------------------------------------------
static void onNotify(NimBLERemoteCharacteristic *c, uint8_t *data, size_t len, bool n) {
  if (g_rxLen + len > sizeof(g_rx)) g_rxLen = 0;
  memcpy(g_rx + g_rxLen, data, len);
  g_rxLen += len;
  if (g_proto == PROTO_UNKNOWN) {
    for (size_t i = 0; i < g_rxLen; i++) {
      if (g_rx[i] == 0xA5) { g_proto = PROTO_A5; break; }
      if (g_rx[i] == 0xD2 && i + 1 < g_rxLen && g_rx[i + 1] == 0x03) { g_proto = PROTO_D2; break; }
    }
  }
  if (g_proto == PROTO_A5) a5Consume();
  else if (g_proto == PROTO_D2) d2Consume();
}

class ClientCB : public NimBLEClientCallbacks {
  void onConnect(NimBLEClient *c) override {
    c->updateConnParams(24, 48, 0, 400);
    g_connected = true;
  }
  void onDisconnect(NimBLEClient *c, int r) override {
    g_connected = false; g_bms.valid = false;
    g_proto = PROTO_UNKNOWN; g_rxLen = 0;
    NimBLEDevice::getScan()->start(SCAN_TIME_S, false);
  }
};
static ClientCB g_clientCB;

class ScanCB : public NimBLEScanCallbacks {
  void onResult(const NimBLEAdvertisedDevice *d) override {
    if (!d->haveName()) return;
    const std::string n = d->getName();
    const bool hit = USE_EXACT_NAME ? (n == TARGET_NAME_EXACT)
                                    : (n.rfind(TARGET_NAME_PREFIX, 0) == 0);
    if (!hit) return;
    g_bms.rssi = d->getRSSI();
    NimBLEDevice::getScan()->stop();
    g_target = const_cast<NimBLEAdvertisedDevice *>(d);
    g_doConnect = true;
  }
};
static ScanCB g_scanCB;

static bool connectToBms() {
  if (!g_client) {
    g_client = NimBLEDevice::createClient();
    g_client->setClientCallbacks(&g_clientCB, false);
    g_client->setConnectTimeout(10000);
  }
  if (!g_client->connect(g_target)) return false;
  NimBLERemoteService *svc = g_client->getService(SVC_UUID);
  if (!svc) { g_client->disconnect(); return false; }
  NimBLERemoteCharacteristic *nf = svc->getCharacteristic(CHR_NOTIFY);
  g_chrWrite = svc->getCharacteristic(CHR_WRITE);
  if (!nf || !g_chrWrite || !nf->subscribe(true, onNotify)) { g_client->disconnect(); return false; }
  
  a5Send(A5_SOC); 
  uint32_t t = millis(); while(millis() - t < 400) { feedGPS(); delay(5); }
  
  if (g_proto == PROTO_UNKNOWN) { 
    d2SendReadAll(); 
    t = millis(); while(millis() - t < 400) { feedGPS(); delay(5); }
  }
  return true;
}

static void pollBms() {
  if (g_proto == PROTO_D2) { d2SendReadAll(); return; }
  static const uint8_t cmds[] = { A5_SOC, A5_MOS, A5_STATUS, A5_CELL_V, A5_CELL_T, A5_BALANCE, A5_FAULTS };
  
  for (uint8_t c : cmds) { 
    a5Send(c); 
    
    // Non-blocking wait: Keep GPS parsed and WebUI responsive during polling pauses
    uint32_t t = millis();
    while (millis() - t < 50) {
      feedGPS();
      server.handleClient();
      delay(1);
    }
  }
  if (g_proto == PROTO_UNKNOWN) d2SendReadAll();
}

// ---------------------------------------------------------------------------
// JSON API
