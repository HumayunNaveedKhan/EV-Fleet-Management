static void handleData() {
  String j = "{";
  j += "\"id\":\"" BIKE_ID "\"";
  j += ",\"ok\":" + String(g_connected && g_bms.valid &&
        (millis() - g_bms.lastUpdateMs < STALE_TIMEOUT_MS) ? 1 : 0);
  j += ",\"rssi\":" + String(g_bms.rssi);
  j += ",\"v\":" + String(g_bms.packVoltage, 1);
  j += ",\"i\":" + String(g_bms.current, 1);
  j += ",\"kw\":" + String(g_bms.powerKW, 3);
  j += ",\"soc\":" + String(g_bms.soc, 1);
  j += ",\"ah\":" + String(g_bms.remainingAh, 1);
  j += ",\"ahn\":" + String(PACK_NOMINAL_AH, 0);
  j += ",\"ein\":" + String((float)g_bms.kWhIn, 3);
  j += ",\"eout\":" + String((float)g_bms.kWhOut, 3);
  j += ",\"cyc\":" + String(g_bms.cycles);
  j += ",\"ns\":" + String(g_bms.cellCount);
  j += ",\"avg\":" + String(g_bms.avgCellmV);
  j += ",\"dmv\":" + String(g_bms.cellDeltamV);
  j += ",\"mn\":" + String(g_bms.minCellmV);
  j += ",\"mni\":" + String(g_bms.minCellNum);
  j += ",\"mx\":" + String(g_bms.maxCellmV);
  j += ",\"mxi\":" + String(g_bms.maxCellNum);
  j += ",\"hv\":\"" + String(deltaVerdict()) + "\"";
  j += ",\"st\":" + String(g_bms.chargeState);
  j += ",\"chg\":" + String(g_bms.chgMos ? 1 : 0);
  j += ",\"dsg\":" + String(g_bms.dsgMos ? 1 : 0);
  j += ",\"bal\":" + String(g_bms.balancing ? 1 : 0);
  j += ",\"life\":" + String(g_bms.bmsLife);
  j += ",\"up\":" + String(millis() / 1000);

  // -- GPS DATA APPENDED --
  j += ",\"lat\":" + String(gps.location.isValid() ? gps.location.lat() : 0.0, 6);
  j += ",\"lng\":" + String(gps.location.isValid() ? gps.location.lng() : 0.0, 6);
  j += ",\"spd\":" + String(gps.speed.isValid() ? gps.speed.kmph() : 0.0, 1);
  j += ",\"sats\":" + String(gps.satellites.isValid() ? gps.satellites.value() : 0);
  j += ",\"hdop\":" + String(gps.hdop.isValid() ? gps.hdop.hdop() : 99.9, 1);

  j += ",\"t\":[";
  for (uint8_t i = 0; i < g_bms.tempCount; i++) { if (i) j += ','; j += String(g_bms.tempC[i]); }
  j += "],\"c\":[";
  for (uint8_t i = 0; i < g_bms.cellCount; i++) { if (i) j += ','; j += String(g_bms.cellmV[i]); }
  j += "],\"f\":[";
  bool first = true;
  for (uint8_t b = 0; b < 7; b++)
    for (uint8_t bit = 0; bit < 8; bit++)
      if (g_bms.faultBytes[b] & (1 << bit)) {
        if (!first) j += ',';
        j += "\"" + String(FAULT_NAMES[b][bit]) + "\"";
        first = false;
      }
  j += "]}";
  server.send(200, "application/json", j);
}

