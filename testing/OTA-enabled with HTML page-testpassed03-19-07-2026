static String deltaVerdict() {
  if (fabsf(g_bms.current) > REST_CURRENT_A) return "UNDER LOAD";
  const uint16_t d = g_bms.cellDeltamV;
  if (d < DELTA_WATCH_MV) return "HEALTHY";
  if (d < DELTA_INVESTIGATE) return "WATCH";
  if (d < DELTA_ALARM_MV) return "INVESTIGATE";
  return "ALARM";
}

