   "Pack overvolt L1","Pack overvolt L2","Pack undervolt L1","Pack undervolt L2"},
  {"Chg temp high L1","Chg temp high L2","Chg temp low L1","Chg temp low L2",
   "Dsg temp high L1","Dsg temp high L2","Dsg temp low L1","Dsg temp low L2"},
  {"Chg overcurrent L1","Chg overcurrent L2","Dsg overcurrent L1","Dsg overcurrent L2",
   "SOC high L1","SOC high L2","SOC low L1","SOC low L2"},
  {"Diff volt L1","Diff volt L2","Diff temp L1","Diff temp L2",
   "-","-","-","-"},
  {"Chg MOS temp high","Dsg MOS temp high","Chg MOS temp sensor fail",
   "Dsg MOS temp sensor fail","Chg MOS adhesion fail","Dsg MOS adhesion fail",
   "Chg MOS open fail","Dsg MOS open fail"},
  {"AFE collect fail","Voltage collect drop","Cell temp sensor fail",
   "EEPROM fail","RTC fail","Precharge fail","Comms fail","Internal comms fail"},
  {"Current module fail","Pack volt detect fail","Short circuit protect fail",
