// ---------------------------------------------------------------------------
// DATA MODEL
// ---------------------------------------------------------------------------
struct DalyData {
  // pack
  float    packVoltage  = 0;     // V
  float    current      = 0;     // A   (+charge / -discharge)
  float    powerW       = 0;     // W
  float    powerKW      = 0;     // kW  -> app "Power KW"
  float    soc          = 0;     // %
  float    remainingAh  = 0;     // Ah
  uint16_t cycles       = 0;

  // cells
  uint8_t  cellCount    = 0;
  uint16_t cellmV[MAX_CELLS] = {0};
  uint16_t maxCellmV    = 0;
  uint16_t minCellmV    = 0;
  uint16_t avgCellmV    = 0;     // -> app "Average volt"
  uint8_t  maxCellNum   = 0;
  uint8_t  minCellNum   = 0;
  uint16_t cellDeltamV  = 0;     // -> app "voltage difference"

  // thermal
  uint8_t  tempCount    = 0;
  int8_t   tempC[MAX_TEMPS] = {0};
  int8_t   maxTempC     = 0;
  int8_t   minTempC     = 0;

  // states
  bool     chgMos       = false;
  bool     dsgMos       = false;
  bool     balancing    = false;
  uint8_t  chargeState  = 0;     // 0 idle / 1 charging / 2 discharging
  uint8_t  bmsLife      = 0;     // rolls 0..255 each poll = liveness proof

  // faults  -> app "Status information"
  uint8_t  faultBytes[7] = {0};
  bool     anyFault     = false;

  // energy
  double   kWhIn        = 0;     // cumulative charged
  double   kWhOut       = 0;     // cumulative discharged

  // meta
  bool     valid        = false;
  uint32_t lastUpdateMs = 0;
};

static DalyData g_bms;

// ---------------------------------------------------------------------------
// BLE STATE
// ---------------------------------------------------------------------------
enum Protocol : uint8_t { PROTO_UNKNOWN = 0, PROTO_A5 = 0xA5, PROTO_D2 = 0xD2 };
static Protocol g_proto = PROTO_UNKNOWN;

static NimBLEClient               *g_client   = nullptr;
static NimBLERemoteCharacteristic *g_chrWrite = nullptr;
static NimBLEAdvertisedDevice     *g_target   = nullptr;

static volatile bool g_doConnect = false;
static volatile bool g_connected = false;

static uint8_t g_rx[512];
static size_t  g_rxLen = 0;

// ---------------------------------------------------------------------------
// HELPERS
// ---------------------------------------------------------------------------
static uint16_t be16(const uint8_t *p) { return (uint16_t)p[0] << 8 | p[1]; }
static uint32_t be32(const uint8_t *p) {
  return (uint32_t)p[0] << 24 | (uint32_t)p[1] << 16 | (uint32_t)p[2] << 8 | p[3];
}

static uint16_t crc16(const uint8_t *buf, size_t len) {
  uint16_t crc = 0xFFFF;
  for (size_t i = 0; i < len; i++) {
    crc ^= buf[i];
    for (uint8_t b = 0; b < 8; b++)
      crc = (crc & 1) ? (crc >> 1) ^ 0xA001 : crc >> 1;
  }
  return crc;
}

static void hexdump(const char *tag, const uint8_t *p, size_t n) {
  Serial.printf("%s [%u] ", tag, (unsigned)n);
  for (size_t i = 0; i < n; i++) Serial.printf("%02X ", p[i]);
  Serial.println();
}

// ---------------------------------------------------------------------------
// FAULT FLAG NAMES  (0x98) — 7 bytes x 8 bits
// ---------------------------------------------------------------------------
static const char *FAULT_NAMES[7][8] = {
