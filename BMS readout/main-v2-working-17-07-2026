static const char *TARGET_NAME_EXACT  = "DL-1771060607EB";
static const char *TARGET_NAME_PREFIX = "DL-";
static const bool  USE_EXACT_NAME     = true;   // false = first DL-* seen

static const uint32_t POLL_INTERVAL_MS = 2000;
static const uint32_t SCAN_TIME_S      = 5;
static const uint32_t STALE_TIMEOUT_MS = 15000;

#define MAX_CELLS 32
#define MAX_TEMPS 8

static NimBLEUUID SVC_UUID  ("0000fff0-0000-1000-8000-00805f9b34fb");
static NimBLEUUID CHR_NOTIFY("0000fff1-0000-1000-8000-00805f9b34fb"); // BMS -> us
