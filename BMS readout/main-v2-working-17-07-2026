#define CELL_MAX_V         3.65f
#define CELL_MIN_V         2.50f

// Cell-delta health thresholds (mV) — baseline this pack measured 2 mV @ 25 cyc
#define DELTA_WATCH_MV     20
#define DELTA_INVESTIGATE  50
#define DELTA_ALARM_MV     100

